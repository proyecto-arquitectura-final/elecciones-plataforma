# Imágenes publicadas por GitHub Actions.
BACKEND_IMAGE=ghcr.io/proyecto-arquitectura-final/elecciones-backend:latest
FRONTEND_IMAGE=ghcr.io/proyecto-arquitectura-final/elecciones-frontend:latest

# PostgreSQL interno.
POSTGRES_DB=elecciones2026
POSTGRES_USER=elecciones
POSTGRES_PASSWORD=CAMBIAR_POR_UNA_CLAVE_LARGA_Y_ALEATORIA

# Dominio público. El DNS A debe apuntar a la IP estática de Lightsail.
APP_SITE_ADDRESS=elecciones.tudominio.com
APP_PUBLIC_URL=https://elecciones.tudominio.com
ACME_EMAIL=correo@tudominio.com

# JWT: valor aleatorio de al menos 32 caracteres.
APP_JWT_SECRET=CAMBIAR_POR_UN_SECRETO_ALEATORIO_DE_AL_MENOS_32_CARACTERES

# Datos iniciales.
APP_SEED_ENABLED=true
APP_SEED_ADMIN_NAME=Administrador
APP_SEED_ADMIN_EMAIL=admin@tudominio.com
APP_SEED_ADMIN_PASSWORD=CAMBIAR_ADMIN_PASSWORD
APP_SEED_ANALYST_NAME=Analista Electoral
APP_SEED_ANALYST_EMAIL=analista@tudominio.com
APP_SEED_ANALYST_PASSWORD=CAMBIAR_ANALISTA_PASSWORD

JAVA_OPTS=-XX:MaxRAMPercentage=75.0 -XX:+ExitOnOutOfMemoryError
